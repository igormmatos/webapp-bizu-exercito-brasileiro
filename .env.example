# Frontend runtime environment (Vite).
# Required for online mode (catalog + suggestions via Supabase).
VITE_PUBLIC_APP_URL=https://<your-public-domain>
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<supabase-anon-public-jwt>

# Optional server/runtime canonical origin for Node hosting (Hostinger/VPS).
PUBLIC_APP_URL=https://<your-public-domain>
